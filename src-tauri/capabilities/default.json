{
  "identifier": "default",
  "description": "Vane default capabilities",
  "windows": [
    "main",
    "settings"
  ],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "core:window:allow-close",
    "core:window:allow-hide",
    "core:window:allow-show",
    "core:window:allow-start-dragging",
    "core:app:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/winws",
          "cmd": "",
          "sidecar": true,
          "args": true
        }
      ]
    },
    "shell:allow-kill",
    "shell:allow-open",
    "process:default",
    "process:allow-exit",
    "store:allow-get",
    "store:allow-set",
    "store:allow-save",
    "store:allow-load",
    "store:allow-delete",
    "updater:default",
    "updater:allow-check",
    "updater:allow-download-and-install",
    "dialog:default",
    "fs:default"
  ]
}